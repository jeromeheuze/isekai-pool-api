APP_NAME="Isekai Pool API"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=UTC
APP_URL=https://api.isekai-pool.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

APP_MAINTENANCE_DRIVER=file

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=warning

# Use file cache/sessions (recommended). CACHE_STORE=database needs php8.3-sqlite3 AND
# `php artisan migrate` (cache table) or cache:clear fails with "no such table: cache".
DB_CONNECTION=sqlite

SESSION_DRIVER=file
SESSION_LIFETIME=120

QUEUE_CONNECTION=sync

CACHE_STORE=file

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

MAIL_MAILER=log

# RPC credentials — injected on the VPS from node configs
YTN_RPC_USER=isekai_ytn
YTN_RPC_PASS=
YTN_RPC_PORT=9982

KOTO_RPC_USER=isekai_koto
KOTO_RPC_PASS=
KOTO_RPC_PORT=8432

TDC_RPC_USER=isekai_tdc
TDC_RPC_PASS=
TDC_RPC_PORT=9368

SUGAR_RPC_USER=isekai_sugar
SUGAR_RPC_PASS=
SUGAR_RPC_PORT=34229
