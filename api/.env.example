APP_NAME="Isekai Pool API"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://api.isekai-pool.com

LOG_CHANNEL=stack
LOG_LEVEL=warning

DB_CONNECTION=sqlite

CACHE_DRIVER=file
SESSION_DRIVER=file
QUEUE_CONNECTION=sync

# RPC Credentials — injected by vps-init.sh from node configs
YTN_RPC_USER=isekai_ytn
YTN_RPC_PASS=
YTN_RPC_PORT=9982

KOTO_RPC_USER=isekai_koto
KOTO_RPC_PASS=
KOTO_RPC_PORT=8432

TDC_RPC_USER=isekai_tdc
TDC_RPC_PASS=
TDC_RPC_PORT=9368

SUGAR_RPC_USER=isekai_sugar
SUGAR_RPC_PASS=
SUGAR_RPC_PORT=34229
